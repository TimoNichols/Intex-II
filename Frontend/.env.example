# =============================================================================
# Frontend environment variables (Vite)
# =============================================================================
# Copy this file to .env.local, fill in real values, and DO NOT commit
# .env.local to source control.
#
# Vite only exposes variables prefixed with VITE_ to browser code.
# Everything else is stripped from the bundle at build time.
# =============================================================================

# ---------------------------------------------------------------------------
# Dev-only auth stub
# Used by src/auth/devCredentials.ts for local login bypass.
# Remove once the real /api/auth/login integration is wired up.
# ---------------------------------------------------------------------------

# The email address accepted by the temporary front-end-only login check.
VITE_DEV_LOGIN_EMAIL=admin@harbor.dev

# The password accepted by the temporary front-end-only login check.
# Must satisfy the backend password policy (12+ chars, upper, lower, digit, symbol).
VITE_DEV_LOGIN_PASSWORD=replace_me_with_a_strong_password

# ---------------------------------------------------------------------------
# API base URL
# The backend API that the React app talks to.
# In production this will be your Azure App Service URL.
# ---------------------------------------------------------------------------
VITE_API_BASE_URL=https://localhost:7156
