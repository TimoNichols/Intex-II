# =============================================================================
# Backend environment variables — ASP.NET Core / Azure App Service
# =============================================================================
# This file is committed to source control as documentation ONLY.
# Real values must be set in:
#   - Local dev:    Backend/Intex.Api/appsettings.Development.json  (gitignored)
#                   OR the "environmentVariables" block in launchSettings.json
#   - Azure:        App Service → Settings → Environment variables
#                   (formerly "Configuration > Application Settings")
#
# .NET maps environment variables to IConfiguration using double-underscore
# as a section separator, e.g.:
#   ConnectionStrings__DefaultConnection  →  ConnectionStrings:DefaultConnection
#   Seed__AdminEmail                      →  Seed:AdminEmail
# =============================================================================

# ---------------------------------------------------------------------------
# Azure SQL connection string
# Azure App Service injects this automatically if you add the connection string
# under App Service → Settings → Environment variables → Connection strings
# tab (type = SQLAzure). The name must be exactly "DefaultConnection".
# ---------------------------------------------------------------------------
ConnectionStrings__DefaultConnection=Server=YOUR_SERVER.database.windows.net;Database=YOUR_DB;User Id=YOUR_USER;Password=YOUR_PASS;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;

# ---------------------------------------------------------------------------
# Database seeder — seed user credentials
# These accounts are created on first boot if they do not already exist.
# Use strong passwords that satisfy the app's password policy:
#   12+ chars, uppercase, lowercase, digit, symbol, 6+ unique chars.
# ---------------------------------------------------------------------------

# Admin seed account
Seed__AdminEmail=admin@yourdomain.com
Seed__AdminPassword=replace_me_with_a_strong_admin_password

# Donor seed account (created with sample donation history)
Seed__DonorEmail=donor@yourdomain.com
Seed__DonorPassword=replace_me_with_a_strong_donor_password

# ---------------------------------------------------------------------------
# JWT configuration
# All three values are required — the app will refuse to start without them.
# ---------------------------------------------------------------------------

# Signing secret for HMAC-SHA256. Must be at least 32 characters.
# Generate one with: openssl rand -base64 48
Jwt__Secret=replace_me_with_at_least_32_random_characters

# Identifies who issued the token — typically your API's base URL.
Jwt__Issuer=https://your-api.azurewebsites.net

# Identifies who the token is intended for — typically your frontend's URL.
Jwt__Audience=https://your-frontend.azurewebsites.net

# ---------------------------------------------------------------------------
# ASP.NET Core runtime
# ---------------------------------------------------------------------------

# "Production" for Azure, "Development" for local (enables Swagger UI, etc.)
ASPNETCORE_ENVIRONMENT=Production
