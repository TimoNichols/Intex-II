# =============================================================================
# Backend environment variables — ASP.NET Core (local shell / Docker / CI)
# =============================================================================
# The API reads PostgreSQL (Supabase) via Npgsql. Use this file as a reference
# for variable names, or export these in your shell before `dotnet run`.
#
# Preferred local setup (no secrets in shell):
#   1. Copy Backend/Intex.Api/appsettings.Development.json.example
#      → Backend/Intex.Api/appsettings.Development.json (gitignored)
#   2. Paste your Supabase connection string and optional Seed values there.
#
# Alternative: dotnet user-secrets (see Intex.Api.csproj UserSecretsId)
#   dotnet user-secrets set "ConnectionStrings:DefaultConnection" "Host=..."
#
# .NET maps environment variables using double-underscore as section separator:
#   ConnectionStrings__DefaultConnection  →  ConnectionStrings:DefaultConnection
#   Seed__AdminEmail                      →  Seed:AdminEmail
# =============================================================================

# ---------------------------------------------------------------------------
# Supabase / PostgreSQL — get values from Supabase → Project Settings → Database
#
# Option A — Transaction pooler (port 6543), typical for serverless / pooler host:
#   Host=aws-0-REGION.pooler.supabase.com;Port=6543;Database=postgres;
#   Username=postgres.YOUR_PROJECT_REF;Password=YOUR_DB_PASSWORD;
#   SSL Mode=Require;Trust Server Certificate=true
#
# Option B — Direct / session (port 5432), often better for EF Core migrations locally:
#   Host=db.YOUR_PROJECT_REF.supabase.co;Port=5432;Database=postgres;
#   Username=postgres;Password=YOUR_DB_PASSWORD;
#   SSL Mode=Require;Trust Server Certificate=true
# ---------------------------------------------------------------------------
ConnectionStrings__DefaultConnection=Host=YOUR_HOST;Port=5432;Database=postgres;Username=postgres;Password=YOUR_DB_PASSWORD;SSL Mode=Require;Trust Server Certificate=true

# ---------------------------------------------------------------------------
# Database seeder — optional; creates dev accounts on startup if not already present
# Passwords must satisfy the app policy: 12+ chars, upper, lower, digit, symbol, 6+ unique.
# ---------------------------------------------------------------------------
Seed__AdminEmail=admin@yourdomain.com
Seed__AdminPassword=replace_me_with_a_strong_admin_password
Seed__DonorEmail=donor@yourdomain.com
Seed__DonorPassword=replace_me_with_a_strong_donor_password

# ---------------------------------------------------------------------------
# JWT — must match what the API issues and what the frontend expects (see appsettings.json)
# ---------------------------------------------------------------------------
Jwt__Secret=replace_me_with_at_least_32_random_characters
Jwt__Issuer=https://localhost:7156
Jwt__Audience=http://localhost:5173

# ---------------------------------------------------------------------------
# ASP.NET Core
# ---------------------------------------------------------------------------
ASPNETCORE_ENVIRONMENT=Development
